<% if (currentUser) { %>
<aside class="sidebar">
  <div class="sidebar-inner">
    <a href="/" class="sidebar-brand">
      <span class="brand-icon">◈</span>
      <span class="brand-name">OdinBook</span>
    </a>

    <nav class="sidebar-nav">
      <a href="/" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'home' ? 'active' : '' %>">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        <span>Home</span>
      </a>
      <a href="/users" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'people' ? 'active' : '' %>">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
        </svg>
        <span>People</span>
      </a>
      <a href="/users/requests" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'requests' ? 'active' : '' %>">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"/>
        </svg>
        <span>Requests</span>
      </a>
      <a href="/users/<%= currentUser.id %>" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'profile' ? 'active' : '' %>">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
        <span>Profile</span>
      </a>
    </nav>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <img src="<%= currentUser.avatarUrl || '/images/default-avatar.png' %>" alt="avatar" class="avatar-sm">
        <div class="sidebar-user-info">
          <span class="sidebar-user-name"><%= currentUser.displayName %></span>
          <span class="sidebar-user-handle">@<%= currentUser.username %></span>
        </div>
      </div>
      <form action="/auth/logout" method="POST">
        <button type="submit" class="btn-logout" title="Log out">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</aside>
<% } %>