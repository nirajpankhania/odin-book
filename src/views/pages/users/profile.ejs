<%- include('../../partials/header') %>

<div class="profile-cover"></div>

<div class="profile-header">
  <div class="profile-avatar-row">
    <img src="<%= profileUser.avatarUrl || '/images/default-avatar.png' %>" alt="avatar" class="profile-avatar">
    <% if (profileUser.id !== currentUser.id) { %>
      <% if (followStatus === 'ACCEPTED') { %>
        <span class="badge">Following</span>
      <% } else if (followStatus === 'PENDING') { %>
        <span class="badge badge-pending">Requested</span>
      <% } else { %>
        <form action="/follows" method="POST">
          <input type="hidden" name="followingId" value="<%= profileUser.id %>">
          <button type="submit" class="btn-follow">Follow</button>
        </form>
      <% } %>
    <% } %>
  </div>

  <h2 class="profile-display-name"><%= profileUser.displayName %></h2>
  <p class="profile-handle">@<%= profileUser.username %></p>
  <% if (profileUser.bio) { %>
    <p class="profile-bio"><%= profileUser.bio %></p>
  <% } %>

  <div class="profile-stats">
    <div class="stat"><strong><%= followerCount %></strong> <span>Followers</span></div>
    <div class="stat"><strong><%= followingCount %></strong> <span>Following</span></div>
    <div class="stat"><strong><%= profileUser.posts.length %></strong> <span>Posts</span></div>
  </div>
</div>

<div class="profile-posts-header">Posts</div>

<% if (profileUser.posts.length === 0) { %>
  <div class="empty-state">
    <div class="empty-state-icon">◈</div>
    <h3>No posts yet</h3>
    <p>When <%= profileUser.displayName %> posts, it'll show up here</p>
  </div>
<% } else { %>
  <% profileUser.posts.forEach(post => { %>
    <%- include('../../partials/postCard', { post, currentUser }) %>
  <% }) %>
<% } %>

<%- include('../../partials/footer') %>