<%- include('../../partials/header') %>

<div class="page-container">
  <div class="profile-header">
    <img src="<%= profileUser.avatarUrl || '/images/default-avatar.png' %>" alt="avatar" class="avatar-lg">
    <div class="profile-info">
      <h2><%= profileUser.displayName %></h2>
      <p class="text-muted">@<%= profileUser.username %></p>
      <% if (profileUser.bio) { %>
        <p><%= profileUser.bio %></p>
      <% } %>
      <div class="profile-stats">
        <span><strong><%= followerCount %></strong> Followers</span>
        <span><strong><%= followingCount %></strong> Following</span>
        <span><strong><%= profileUser.posts.length %></strong> Posts</span>
      </div>

      <% if (profileUser.id !== currentUser.id) { %>
        <% if (followStatus === 'ACCEPTED') { %>
          <span class="badge">Following</span>
        <% } else if (followStatus === 'PENDING') { %>
          <span class="badge badge-pending">Request Sent</span>
        <% } else { %>
          <form action="/follows" method="POST">
            <input type="hidden" name="followingId" value="<%= profileUser.id %>">
            <button type="submit" class="btn-follow">Follow</button>
          </form>
        <% } %>
      <% } %>
    </div>
  </div>

  <div class="posts-list">
    <h3>Posts</h3>
    <% if (profileUser.posts.length === 0) { %>
      <p class="text-muted">No posts yet.</p>
    <% } else { %>
      <% profileUser.posts.forEach(post => { %>
        <div class="post-card">
          <p><%= post.content %></p>
          <div class="post-meta">
            <span><%= post.likes.length %> likes</span>
            <span><%= post.comments.length %> comments</span>
            <span class="text-muted"><%= post.createdAt.toDateString() %></span>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

</body>
</html>