<%- include('../../partials/header') %>

<div class="page-header">
  <h2>Follow Requests</h2>
</div>

<% if (requests.length === 0) { %>
  <div class="empty-state">
    <div class="empty-state-icon">◈</div>
    <h3>No pending requests</h3>
    <p>When someone requests to follow you, it'll appear here</p>
  </div>
<% } else { %>
  <div class="users-list">
    <% requests.forEach(req => { %>
      <div class="user-card">
        <img src="<%= req.follower.avatarUrl || '/images/default-avatar.png' %>" alt="avatar" class="avatar-sm">
        <div class="user-card-info">
          <a href="/users/<%= req.follower.id %>">@<%= req.follower.username %></a>
          <p><%= req.follower.displayName %></p>
        </div>
        <div class="user-card-action" style="display:flex; gap:0.5rem">
          <form action="/follows/<%= req.follower.id %>/accept" method="POST">
            <button type="submit" class="btn-follow">Accept</button>
          </form>
          <form action="/follows/<%= req.follower.id %>/reject" method="POST">
            <button type="submit" class="btn-action btn-delete">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('../../partials/footer') %>