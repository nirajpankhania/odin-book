<%- include('../partials/header') %>

<div class="page-container">

  <!-- New post form -->
  <div class="new-post-form">
    <img src="<%= currentUser.avatarUrl || '/images/default-avatar.png' %>" alt="avatar" class="avatar-sm">
    <form action="/posts" method="POST" class="post-form">
      <textarea name="content" placeholder="What's happening?" class="post-textarea" maxlength="280"></textarea>
      <div class="post-form-footer">
        <span class="char-count">280</span>
        <button type="submit" class="btn-post">Post</button>
      </div>
    </form>
  </div>

  <div class="divider"></div>

  <!-- Posts feed -->
  <% if (posts.length === 0) { %>
    <div class="empty-feed">
      <p>No posts yet!</p>
      <p class="text-muted">Follow some people or create your first post.</p>
      <a href="/users" class="btn-follow" style="display:inline-block; margin-top:1rem; text-decoration:none;">Find people to follow</a>
    </div>
  <% } else { %>
    <% posts.forEach(post => { %>
      <%- include('../partials/postCard', { post, currentUser }) %>
    <% }) %>
  <% } %>

</div>

</body>
</html>